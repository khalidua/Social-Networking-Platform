SERVICE_NAME=api-gateway
APP_ENV=development
PORT=8080
LOG_LEVEL=info
HTTP_READ_TIMEOUT=10
HTTP_WRITE_TIMEOUT=10
HTTP_IDLE_TIMEOUT=60

AUTH_SERVICE_URL=http://auth-service:8081
USERS_SERVICE_URL=http://users-service:8082
POSTS_SERVICE_URL=http://posts-service:8083
FEED_SERVICE_URL=http://feed-service:8084
NOTIFICATION_SERVICE_URL=http://notification-service:8085

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=change-me
JWT_ISSUER=auth-service

UPSTREAM_TIMEOUT=10s
UPSTREAM_RETRY_ATTEMPTS=3
UPSTREAM_RETRY_BACKOFF=100ms
CIRCUIT_BREAKER_FAILURES=5
CIRCUIT_BREAKER_OPEN_FOR=30s

RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_WINDOW=1m

# TLS mode for direct HTTPS from the gateway.
TLS_ENABLED=false
TLS_CERT_FILE=
TLS_KEY_FILE=

# Use true when gateway is behind a trusted TLS-terminating reverse proxy.
TRUST_PROXY_HEADERS=false

# Require HTTPS either directly via TLS or through X-Forwarded-Proto=https.
REQUIRE_HTTPS=false
