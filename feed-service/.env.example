SERVICE_NAME=feed-service
APP_ENV=development
PORT=8084
LOG_LEVEL=info
HTTP_READ_TIMEOUT=10
HTTP_WRITE_TIMEOUT=10
HTTP_IDLE_TIMEOUT=60
REDIS_HOST=redis
REDIS_PORT=6379
# Internal Docker network listener (see compose). Leave empty to disable Kafka consumers locally.
KAFKA_BROKERS=kafka:29092
KAFKA_TOPIC_POST_CREATED=post.created
KAFKA_TOPIC_USER_FOLLOWED=user.followed
# Base URL of users-service (Docker service name + port). Required for post.created fan-out to real followers.
USERS_SERVICE_URL=http://users-service:8082
