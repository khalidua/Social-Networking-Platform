SERVICE_NAME=posts-service
APP_ENV=development
PORT=8083
LOG_LEVEL=info
HTTP_READ_TIMEOUT=10
HTTP_WRITE_TIMEOUT=10
HTTP_IDLE_TIMEOUT=60
DB_HOST=posts-db
DB_PORT=5432
DB_NAME=posts_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=disable
# Optional; default is ./migrations relative to the process working directory. In the image, /app/migrations is copied next to the binary.
# MIGRATIONS_DIR=/app/migrations
KAFKA_BROKERS=kafka:29092
KAFKA_TOPIC_POST_CREATED=post.created
