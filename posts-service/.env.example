SERVICE_NAME=posts-service
APP_ENV=development
PORT=8083
LOG_LEVEL=info
HTTP_READ_TIMEOUT=10
HTTP_WRITE_TIMEOUT=10
HTTP_IDLE_TIMEOUT=60
DB_HOST=posts-db
DB_PORT=5432
DB_NAME=posts_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=disable
# Internal listener (match docker compose). Leave empty to disable Kafka publish (no-op producer).
KAFKA_BROKERS=kafka:29092
KAFKA_TOPIC_POST_CREATED=post.created
